{
  "name": "mkbaker/jackanswers",
  "description": "Dockerized Symfony application.",
  "type": "project",
  "license": "proprietary",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": ">=8.4",
    "symfony/asset": "8.0.*",
    "symfony/asset-mapper": "8.0.*",
    "symfony/console": "8.0.*",
    "symfony/dotenv": "8.0.*",
    "symfony/flex": "^2",
    "symfony/framework-bundle": "8.0.*",
    "symfony/runtime": "8.0.*",
    "symfony/security-csrf": "8.0.*",
    "symfony/stimulus-bundle": "^3.1",
    "symfony/twig-bundle": "8.0.*",
    "symfony/ux-turbo": "^3.1",
    "symfony/yaml": "8.0.*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true
    },
    "sort-packages": true
  },
  "extra": {
    "symfony": {
      "require": "8.0.*"
    },
    "runtime": {
      "class": "Symfony\\Component\\Runtime\\SymfonyRuntime"
    }
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd",
      "importmap:install": "symfony-cmd"
    }
  }
}
